programa {
  funcao inicio() {
    //QUESTÃO 1 — Contagem simples
    //Desenvolva um algoritmo que exiba na tela os números de 1 até 10 utilizando a estrutura enquanto.

    inteiro contador = 1
    
    enquanto (contador <= 10) {
      escreva(contador, "\n")
      
      contador = contador + 1
    }
  }
}
