programa {
  funcao inicio() {
    //QUESTÃO 3 — Exibindo nomes
    //Desenvolva um algoritmo que exiba o nome “Algoritmo” 5 vezes na tela utilizando enquanto.

    inteiro contador = 1
    
    enquanto (contador <= 5) {
      escreva("Algoritmo\n")
      
      contador = contador + 1
    }
  }
}
